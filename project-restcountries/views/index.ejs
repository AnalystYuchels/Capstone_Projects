<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Search for any country and explore its details instantly.">
  <title>RestCountries Explorer</title>
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
  
  <header class="site-header">
    <div class="header-inner">
      <h1>🌍 RestCountries Explorer</h1>
      <p>Search for any country and explore its details instantly.</p>
    </div>
  </header>

  <main class="main-content">

    <!-- Search Form -->
    <section class="search-section">
      <form action="/search" method="POST" class="search-form" novalidate>
        <label for="country" class="visually-hidden">Enter a country name</label>
        <input 
          type="text"
          id="country"
          name="country"
          placeholder="Enter a country name e.g. Nigeria"
          autocomplete="off"
          required
        >
        <button type="submit">Search</button>
      </form>

      <!-- Error message - only renders if the error variable is not null -->
      <% if (error) { %>
        <div class="error-box" role="alert">
          <p>⚠️ <%= error %></p>
        </div>
      <% } %>
    </section>

    <!-- Hint Cards -->
    <section class="hints">
      <p class="hints-title">Try searching for:</p>
      <div class="hint-tags">
        <span class="tag">🇳🇬 Nigeria</span>
        <span class="tag">🇯🇵 Japan</span>
        <span class="tag">🇧🇷 Brazil</span>
        <span class="tag">🇩🇪 Germany</span>
        <span class="tag">🇦🇺 Australia</span>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <p>Powered by <a href="https://restcountries.com" target="_blank" rel="noopener noreferrer">REST Countries API</a></p>
  </footer>
</body>
</html>